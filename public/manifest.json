{
  "manifest_version": 3,
  "name": "Inspire - A Better New Tab",
  "version": "0.1.1",
  "description": "A better new tab: life clock, daily todos, quotes, sticky notes, and a Pinterest-style pins wall.",
  "chrome_url_overrides": { "newtab": "newtab.html" },
  "background": { "service_worker": "background.js", "type": "module" },
  "permissions": ["storage", "unlimitedStorage", "contextMenus"],
  "host_permissions": ["https://api.trello.com/*", "https://zenquotes.io/*"],
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
}
