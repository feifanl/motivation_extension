{
  "manifest_version": 3,
  "name": "Memento Mori: A Motivation Extension",
  "version": "0.1.0",
  "description": "A memento-mori dashboard: life clock, daily todos, quotes, and Pinterest pins.",
  "chrome_url_overrides": { "newtab": "newtab.html" },
  "background": { "service_worker": "background.js", "type": "module" },
  "permissions": ["storage", "unlimitedStorage", "contextMenus"],
  "host_permissions": ["https://api.trello.com/*", "https://zenquotes.io/*"],
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
}
